# Configuracoes da aplicacao
APP_NAME=PayvoraX
VERSION=1.0.0
DEBUG=False

# Database (Neon PostgreSQL recomendado para producao)
DATABASE_URL=postgresql://user:password@host/dbname

# Security (TROCAR EM PRODUCAO: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Logging
LOG_LEVEL=INFO

# Payment Gateway Integration (BaaS interno)
# CRITICAL: NEVER commit .env with real keys
ASAAS_API_KEY=your-asaas-api-key-here
ASAAS_USE_SANDBOX=true

# Email transacional via Resend (https://resend.com)
# CRITICAL: use APENAS via variavel de ambiente — nunca inclua a chave real neste arquivo.
# No Render: Settings > Environment > Add Environment Variable
# Localmente: adicione no seu .env (que esta no .gitignore)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_NAME=PayvoraX
RESEND_FROM_EMAIL=noreply@payvorax.com

# URL base da aplicacao (usado nos links de email)
APP_BASE_URL=https://seu-dominio.onrender.com
